{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 550,
  "title": {
    "text": "Toàn cảnh Vết tích Cháy rừng tại Victoria (2010 - Nay)",
    "fontSize": 18,
    "subtitle": "Các khu vực cháy chồng chéo lên nhau sẽ có màu đậm hơn",
    "subtitleFontStyle": "italic"
  },
  "data": {
    "url": "data/FIRE_HISTORY.json",
    "format": {
      "type": "topojson",
      "feature": "FIRE_HISTORY"
    }
  },
  "mark": {
    "type": "geoshape",
    "stroke": "#ffffff",
    "strokeWidth": 0.2,
    "opacity": 0.6,
    "blend": "multiply" 
  },
  "encoding": {
    "color": {
      "field": "properties.CAUSE",
      "type": "nominal",
      "title": "Nguyên nhân gây cháy",
      "scale": {"scheme": "dark2"}
    },
    "tooltip": [
      {"field": "properties.SEASON", "type": "quantitative", "title": "Năm xảy ra"},
      {"field": "properties.CAUSE", "type": "nominal", "title": "Nguyên nhân"}
    ]
  }
}