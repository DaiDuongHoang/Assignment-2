            "size": 50,
            "fill": "#1a1a1a",
            "stroke": "#ffffff",
            "strokeWidth": 1.2
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"}
          }
        },
        {
          "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": 700,
            "dy": -10,
            "dx": 13,
            "xOffset": 2,
            "align": "right",
            "fill": "#2f2f2f",
            "opacity": 0.85
