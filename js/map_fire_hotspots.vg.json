  "config": {
    "view": {"stroke": null},
    "background": "transparent",
    "legend": {
      "orient": "top-right",
      "fillColor": "#ffffff",
      "strokeColor": "#cccccc",
      "padding": 12,
      "cornerRadius": 5,
      "offset": 10
    }
  }
  
